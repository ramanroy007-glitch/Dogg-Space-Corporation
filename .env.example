PORT=3000
NODE_ENV=production
# Admin credentials — CHANGE THESE IMMEDIATELY
ADMIN_USER=admin
ADMIN_PASS=CHANGE_THIS_TO_STRONG_PASSWORD
# Your domain (used for CORS and verification)
ALLOWED_ORIGIN=https://yourdomain.com
# Data directory
DATA_DIR=/app/data
# ESP Webhooks (optional — add any you use)
BREVO_WEBHOOK=
ACTIVECAMPAIGN_WEBHOOK=
CONVERTKIT_WEBHOOK=
GOOGLE_SHEET_WEBHOOK=

# Real-time Email Verification (ZeroBounce / Kickbox) (optional — can also be set in Admin panel)
EMAIL_VERIFIER_SERVICE=none # Options: none, zerobounce, kickbox
ZEROBOUNCE_API_KEY=
KICKBOX_API_KEY=
